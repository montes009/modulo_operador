---
import '../styles/global.css';
import FlowDemo from '../components/FlowDemo.astro';

// Íconos SVG monocromáticos (línea) — se pintan con el degradado plata #silver.
const ic = {
  fleet:     '<path d="M3 16V6a1 1 0 0 1 1-1h10v11M14 9h4l3 3v4h-3M6 19a1.6 1.6 0 1 0 0-3.2A1.6 1.6 0 0 0 6 19ZM17 19a1.6 1.6 0 1 0 0-3.2A1.6 1.6 0 0 0 17 19Z"/>',
  doc:       '<path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5Z"/><path d="M14 3v5h5M9 13h6M9 17h6"/>',
  truck:     '<path d="M3 16V6a1 1 0 0 1 1-1h10v11M14 9h4l3 3v4h-3M6 19a1.6 1.6 0 1 0 0-3.2A1.6 1.6 0 0 0 6 19ZM17 19a1.6 1.6 0 1 0 0-3.2A1.6 1.6 0 0 0 17 19Z"/>',
  wrench:    '<path d="M14.7 6.3a4 4 0 0 0-5.4 5.4l-5.6 5.6a2 2 0 0 0 2.8 2.8l5.6-5.6a4 4 0 0 0 5.4-5.4l-2.6 2.6-1.8-.4-.4-1.8 2.6-2.6Z"/>',
  gear:      '<path d="M12 15.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z"/><path d="M19 12a7 7 0 0 0-.1-1l2-1.5-2-3.4-2.3 1a7 7 0 0 0-1.7-1L14.6 3h-4l-.3 2.6a7 7 0 0 0-1.7 1l-2.3-1-2 3.4 2 1.5a7 7 0 0 0 0 2l-2 1.5 2 3.4 2.3-1a7 7 0 0 0 1.7 1l.3 2.6h4l.3-2.6a7 7 0 0 0 1.7-1l2.3 1 2-3.4-2-1.5a7 7 0 0 0 .1-1Z"/>',
  wallet:    '<path d="M3 7a2 2 0 0 1 2-2h12v3M3 7v10a2 2 0 0 0 2 2h14a1 1 0 0 0 1-1v-3M3 7h16a1 1 0 0 1 1 1v3h-5a2 2 0 1 0 0 4h5"/>',
  chart:     '<path d="M5 20V11M12 20V4M19 20v-6M3 20h18"/>',
  pin:       '<path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z"/><path d="M12 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/>',
  crown:     '<path d="M3 8l4.5 4.5L12 5l4.5 7.5L21 8l-1.6 10.5H4.6L3 8Z"/><path d="M4.6 18.5h14.8"/>',
  building:  '<path d="M4 21V5a1 1 0 0 1 1-1h9a1 1 0 0 1 1 1v16M15 10h4a1 1 0 0 1 1 1v10M3 21h18M8 8h3M8 12h3M8 16h3"/>',
  briefcase: '<path d="M4 8h16a1 1 0 0 1 1 1v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9a1 1 0 0 1 1-1Z"/><path d="M9 8V6a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2M3 13h18"/>',
};

const features = [
  { key:'fleet',  tag:'Flota', title:'Control total de equipos', desc:'Cada máquina con su estado real en vivo: disponible, reservado, trabajando, en taller o varada. Hoja de vida, horómetro y medidores.', color:'var(--navy-400)' },
  { key:'doc',    tag:'Alquileres', title:'Cotizar y alquilar en minutos', desc:'De cotización a alquiler activo con PDFs de marca, condiciones por empresa y facturación por días reales o cortes.', color:'var(--cyan)' },
  { key:'truck',  tag:'Logística', title:'Despachos y devoluciones trazados', desc:'Órdenes de entrega, recogida y traslado con transportador, ruta y estado. Sin equipos “perdidos” entre obras.', color:'var(--yellow)' },
  { key:'wrench', tag:'Taller', title:'Alistamiento con checklist obligatorio', desc:'Nada sale a la calle sin pasar el checklist de seguridad. Vencimientos, mecánico y aprobación en un paso.', color:'var(--red)' },
  { key:'gear',   tag:'Mantenimiento', title:'Órdenes de Servicio en obra', desc:'Preventivos automáticos por tiempo u horómetro para equipos de largo plazo, con técnico, evidencia y firma en sitio.', color:'var(--green)' },
  { key:'wallet', tag:'Caja & Cartera', title:'Movimientos y clientes al día', desc:'Caja, cartera de clientes y documentos centralizados. Sabes quién debe, cuánto y desde cuándo.', color:'var(--green)' },
  { key:'chart',  tag:'Gerencia', title:'Panel gerencial + alertas LIAN', desc:'KPIs, rentabilidad por equipo y un motor de alertas inteligentes que avisa vencimientos, desgaste y riesgos antes de que duelan.', color:'var(--purple)' },
  { key:'pin',    tag:'Operador', title:'Trazabilidad desde la obra', desc:'El operador registra llegada, fotos, checklist y firma del receptor desde el celular. Garantía y respaldo de cada entrega.', color:'var(--navy-300)' },
];

const roles = [
  { key:'crown',     name:'Superadmin', desc:'Gobierna todas las empresas y sedes' },
  { key:'building',  name:'Admin empresa', desc:'Configura su empresa, usuarios y condiciones' },
  { key:'briefcase', name:'Comercial', desc:'Cotiza, alquila y gestiona clientes' },
  { key:'wrench',    name:'Taller', desc:'Alista, repara y aprueba equipos' },
  { key:'truck',     name:'Logística', desc:'Despacha, recoge y traslada' },
  { key:'pin',       name:'Operador', desc:'Trazabilidad y firma en obra' },
];

const solves = [
  { bad:'Equipos alquilados dos veces por error', good:'Reserva automática que bloquea el equipo' },
  { bad:'Máquinas que salen sin revisar', good:'Checklist de seguridad obligatorio antes de salir' },
  { bad:'No saber dónde está cada equipo', good:'Estado en vivo + trazabilidad de logística' },
  { bad:'Preventivos olvidados en obra', good:'Órdenes de servicio automáticas por uso o tiempo' },
  { bad:'Facturar mal los días de alquiler', good:'Facturación por días reales o por cortes' },
  { bad:'Cartera y caja en hojas sueltas', good:'Clientes, caja y documentos en un solo lugar' },
];
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Alcon Ops — El sistema operativo de tu flota de alquiler</title>
  <meta name="description" content="Alcon Ops: gestiona alquiler de maquinaria de punta a punta. Flota, cotizaciones, logística, taller, mantenimiento en obra, caja y gerencia. Multi-empresa, multi-sede, por roles." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
  <noscript><style>[data-reveal]{opacity:1!important;transform:none!important}</style></noscript>
</head>
<body>

<!-- degradado plata/metálico reutilizable para todos los íconos SVG -->
<svg width="0" height="0" aria-hidden="true" style="position:absolute">
  <defs>
    <linearGradient id="silver" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#f6f8fb"/>
      <stop offset="0.45" stop-color="#cdd4e0"/>
      <stop offset="0.55" stop-color="#aab2c2"/>
      <stop offset="1" stop-color="#7c8597"/>
    </linearGradient>
  </defs>
</svg>

<!-- ===================== NAV ===================== -->
<header class="nav" id="nav">
  <div class="wrap nav-in">
    <a class="brand" href="#top">
      <span class="brand-mark">A</span>
      <span class="brand-tx">Alcon<span>Ops</span></span>
    </a>
    <nav class="nav-links">
      <a href="#funciones">Funciones</a>
      <a href="#flujo">Flujo en vivo</a>
      <a href="#soluciona">Qué soluciona</a>
      <a href="#equipos">Tu equipo</a>
    </nav>
    <a href="#cta" class="btn btn-primary nav-cta">Solicitar demo</a>
  </div>
</header>

<!-- ===================== HERO ===================== -->
<section id="top" class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="mesh m1"></div><div class="mesh m2"></div><div class="mesh m3"></div>
    <div class="grid-floor"></div>
    <div class="particles" id="particles"></div>
  </div>

  <div class="wrap hero-in">
    <div class="hero-copy">
      <span class="eyebrow" data-reveal>Software de gestión de alquiler de maquinaria</span>
      <h1 data-reveal data-reveal-delay="1">
        El sistema operativo de tu <span class="grad-text">flota de alquiler</span>.
      </h1>
      <p class="lead" data-reveal data-reveal-delay="2">
        De la cotización a la devolución, Alcon Ops conecta <b>comercial, taller, logística y gerencia</b>
        en un solo flujo vivo. Menos papeles, cero equipos perdidos, decisiones con datos reales.
      </p>
      <div class="hero-cta" data-reveal data-reveal-delay="3">
        <a href="#flujo" class="btn btn-primary">▶ Ver el flujo en vivo</a>
        <a href="#funciones" class="btn btn-ghost">Explorar funciones</a>
      </div>
      <div class="hero-stats" data-reveal data-reveal-delay="4">
        <div class="hstat"><b data-count="8">0</b><span>módulos integrados</span></div>
        <div class="hstat"><b data-count="6">0</b><span>roles operativos</span></div>
        <div class="hstat"><b data-count="100" data-suffix="%">0</b><span>en la nube · PWA</span></div>
      </div>
    </div>

    <!-- ventana viva del hero -->
    <div class="hero-app" data-reveal data-reveal-delay="2" aria-hidden="true">
      <div class="ha-glow"></div>
      <div class="ha-window">
        <div class="ha-bar"><span></span><span></span><span></span><i>Dashboard · Alcon Ops</i></div>
        <div class="ha-body">
          <div class="ha-kpis">
            <div class="ha-kpi"><small>Equipos activos</small><strong class="tick" data-to="37">0</strong><em class="up">▲ trabajando</em></div>
            <div class="ha-kpi"><small>Disponibles</small><strong class="tick" data-to="12">0</strong><em>en bodega</em></div>
            <div class="ha-kpi"><small>En obra</small><strong class="tick" data-to="9">0</strong><em class="amb">OS activas</em></div>
          </div>
          <div class="ha-fleet">
            <div class="ha-fleet-h"><span>Flota en vivo</span><i class="live">● en vivo</i></div>
            <div class="ha-list" id="haList"></div>
          </div>
          <div class="ha-chart">
            <div class="bars">
              {Array.from({length:14}).map((_,i)=>(<span style={`--h:${20+Math.round(Math.abs(Math.sin(i*1.3))*70)}%`}></span>))}
            </div>
            <small>Ocupación de flota · últimos 14 días</small>
          </div>
        </div>
      </div>
      <div class="ha-float f1">🔔 UP-201 · alistamiento vence en 2 días</div>
      <div class="ha-float f2">✅ ALQ-0188 facturado</div>
    </div>
  </div>

  <div class="hero-scroll"><span></span>desliza</div>
</section>

<!-- ===================== LOGOS / CONFIANZA ===================== -->
<section class="trust">
  <div class="wrap trust-in">
    <p>Diseñado con empresas reales de alquiler de maquinaria</p>
    <div class="trust-row">
      <span>🚜 Plataformas</span><span>🏗️ Elevadores</span><span>⚡ Equipos eléctricos</span><span>🔋 Baterías</span><span>📦 Multi-sede</span>
    </div>
  </div>
</section>

<!-- ===================== QUÉ SOLUCIONA ===================== -->
<section id="soluciona" class="sec-pad solves">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow" data-reveal>El problema → la solución</span>
      <h2 class="h-sec" data-reveal data-reveal-delay="1">El caos del alquiler, resuelto.</h2>
      <p class="lead" data-reveal data-reveal-delay="2">Cada dolor del día a día de una flota de alquiler tiene su respuesta dentro de Alcon Ops.</p>
    </div>
    <div class="solve-grid">
      {solves.map((s,i)=>(
        <div class="solve" data-reveal data-reveal-delay={(i%3)+1}>
          <div class="solve-bad"><span class="x">✕</span>{s.bad}</div>
          <div class="solve-arrow">→</div>
          <div class="solve-good"><span class="v">✓</span>{s.good}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===================== FUNCIONES ===================== -->
<section id="funciones" class="sec-pad features">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow" data-reveal>Todo lo que hace</span>
      <h2 class="h-sec" data-reveal data-reveal-delay="1">Ocho módulos, <span class="grad-text">un solo sistema</span>.</h2>
      <p class="lead" data-reveal data-reveal-delay="2">No son apps sueltas: todo comparte el mismo estado en tiempo real. Lo que pasa en taller se ve en comercial; lo que despacha logística llega a gerencia.</p>
    </div>
    <div class="feat-grid">
      {features.map((f,i)=>(
        <article class="feat" data-reveal data-reveal-delay={(i%4)+1} style={`--accent:${f.color}`}>
          <div class="feat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="url(#silver)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={ic[f.key]}></svg></div>
          <span class="feat-tag">{f.tag}</span>
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
          <div class="feat-glow"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ===================== FLUJO EN VIVO (DEMO) ===================== -->
<section id="flujo" class="sec-pad flow">
  <div class="wrap">
    <div class="sec-head center">
      <span class="eyebrow" data-reveal>Demo interactiva</span>
      <h2 class="h-sec" data-reveal data-reveal-delay="1">Mira un equipo recorrer todo el ciclo.</h2>
      <p class="lead" data-reveal data-reveal-delay="2" style="margin:0 auto">Una sola máquina, de la bodega a la obra y de vuelta. Haz clic en cada paso o déjalo correr solo: así se siente operar con Alcon Ops.</p>
    </div>
    <div data-reveal data-reveal-delay="2"><FlowDemo /></div>
  </div>
</section>

<!-- ===================== TU EQUIPO / ROLES ===================== -->
<section id="equipos" class="sec-pad team">
  <div class="wrap team-in">
    <div class="team-copy">
      <span class="eyebrow" data-reveal>¿Cuántas personas pueden operarlo?</span>
      <h2 class="h-sec" data-reveal data-reveal-delay="1">Toda tu operación,<br/><span class="grad-text">cada quien en lo suyo.</span></h2>
      <p class="lead" data-reveal data-reveal-delay="2">Alcon Ops es <b>multi-usuario, multi-sede y multi-empresa</b>. Cada persona ve y hace exactamente lo que su rol necesita —ni más, ni menos— y todos trabajan sobre la misma información en tiempo real.</p>
      <ul class="team-points" data-reveal data-reveal-delay="3">
        <li><span>👥</span> Usuarios ilimitados por empresa, organizados por rol</li>
        <li><span>🏬</span> Varias sedes con datos filtrados automáticamente</li>
        <li><span>🔐</span> Permisos por rol: cada quien ve solo su parte</li>
        <li><span>🔗</span> Alta de usuarios por link de invitación</li>
      </ul>
    </div>
    <div class="team-roles">
      {roles.map((r,i)=>(
        <div class="role" data-reveal data-reveal-delay={(i%3)+1}>
          <span class="role-ic"><svg viewBox="0 0 24 24" fill="none" stroke="url(#silver)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={ic[r.key]}></svg></span>
          <div><b>{r.name}</b><small>{r.desc}</small></div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===================== FÁCIL / INTUITIVA ===================== -->
<section class="sec-pad easy">
  <div class="wrap easy-grid">
    <div class="easy-card big" data-reveal>
      <h3>Tan fácil que se aprende usándolo</h3>
      <p>Pensado para gente de obra y oficina, no para informáticos. Botones claros, flujos guiados y el estado de cada equipo a la vista. Si sabes pedir un alquiler, ya sabes usar Alcon Ops.</p>
      <div class="easy-chips"><span>🖱️ Un clic por acción</span><span>📱 Desde el celular</span><span>🌗 Modo claro/oscuro</span><span>⚡ Sin instalar nada</span></div>
    </div>
    <div class="easy-card" data-reveal data-reveal-delay="1"><div class="ec-ic">☁️</div><h4>100% en la nube</h4><p>Trabaja siempre en línea. Tus datos seguros y sincronizados al instante entre sedes.</p></div>
    <div class="easy-card" data-reveal data-reveal-delay="2"><div class="ec-ic">📲</div><h4>Funciona como app (PWA)</h4><p>Instálala en el celular del operador. Cámara, firma y checklist desde la obra.</p></div>
    <div class="easy-card" data-reveal data-reveal-delay="2"><div class="ec-ic">🔔</div><h4>Te avisa antes</h4><p>Alertas inteligentes de vencimientos, desgaste y devoluciones para adelantarte a los problemas.</p></div>
    <div class="easy-card" data-reveal data-reveal-delay="3"><div class="ec-ic">🧾</div><h4>Documentos de marca</h4><p>Cotizaciones, alquileres y hojas de vida en PDF con las condiciones de tu empresa.</p></div>
  </div>
</section>

<!-- ===================== CTA FINAL ===================== -->
<section id="cta" class="sec-pad cta">
  <div class="cta-bg" aria-hidden="true"><div class="mesh m1"></div><div class="mesh m2"></div></div>
  <div class="wrap cta-in" data-reveal>
    <h2 class="h-sec">¿Listo para ver tu flota <span class="grad-text">con vida propia</span>?</h2>
    <p class="lead" style="margin:0 auto">Te mostramos Alcon Ops con tus propios equipos y tu operación. Sin compromiso.</p>
    <div class="hero-cta" style="justify-content:center">
      <a href="https://www.alconops.com" target="_blank" rel="noopener" class="btn btn-primary">Solicitar una demo</a>
      <a href="#flujo" class="btn btn-ghost">Volver a ver el flujo</a>
    </div>
  </div>
</section>

<footer class="foot">
  <div class="wrap foot-in">
    <div class="brand"><span class="brand-mark">A</span><span class="brand-tx">Alcon<span>Ops</span></span></div>
    <p>El sistema operativo de tu flota de alquiler.</p>
    <small>© 2026 Alcon Ops · Hecho para empresas de alquiler de maquinaria.</small>
  </div>
</footer>

<style>
/* ---------- NAV ---------- */
.nav{position:fixed;top:0;left:0;right:0;z-index:50;transition:.3s}
.nav-in{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;margin:10px auto;border-radius:999px;border:1px solid transparent}
.nav.scrolled .nav-in{background:rgba(10,22,38,.7);backdrop-filter:blur(14px);border-color:var(--line)}
.brand{display:flex;align-items:center;gap:10px;font-family:var(--font-display);font-weight:700;font-size:19px;color:#fff}
.brand-mark{width:34px;height:34px;border-radius:10px;background:var(--grad-red);display:grid;place-items:center;font-weight:800;box-shadow:var(--shadow-red)}
.brand-tx span{color:var(--red)}
.nav-links{display:flex;gap:28px;font-size:14.5px;font-weight:500;color:var(--txt-2)}
.nav-links a{position:relative;transition:.2s}
.nav-links a:hover{color:#fff}
.nav-links a::after{content:"";position:absolute;left:0;bottom:-5px;height:2px;width:0;background:var(--red);transition:.25s}
.nav-links a:hover::after{width:100%}
.nav-cta{padding:10px 20px;font-size:14px}
@media (max-width:820px){.nav-links{display:none}}

/* ---------- HERO ---------- */
.hero{position:relative;min-height:100vh;display:flex;align-items:center;padding:120px 0 60px;overflow:hidden}
.hero-bg{position:absolute;inset:0;z-index:0;overflow:hidden}
.mesh{position:absolute;border-radius:50%;filter:blur(70px);opacity:.55;animation:drift 18s ease-in-out infinite}
.hero .m1{width:620px;height:620px;background:radial-gradient(circle,#1B4A7A,transparent 70%);top:-180px;left:-120px}
.hero .m2{width:560px;height:560px;background:radial-gradient(circle,#E11D38,transparent 70%);bottom:-200px;right:-120px;opacity:.4;animation-delay:-6s}
.hero .m3{width:480px;height:480px;background:radial-gradient(circle,#22D3EE,transparent 70%);top:30%;right:30%;opacity:.22;animation-delay:-11s}
@keyframes drift{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(40px,-30px) scale(1.08)}66%{transform:translate(-30px,25px) scale(.95)}}
.grid-floor{position:absolute;inset:0;background-image:linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px);background-size:54px 54px;mask:radial-gradient(120% 80% at 50% 0,#000 30%,transparent 75%);opacity:.5}
.particles{position:absolute;inset:0}
.particles i{position:absolute;width:4px;height:4px;border-radius:50%;background:var(--red);opacity:.5;animation:floatUp linear infinite}
@keyframes floatUp{from{transform:translateY(20px);opacity:0}10%{opacity:.6}90%{opacity:.6}to{transform:translateY(-110vh);opacity:0}}

.hero-in{position:relative;z-index:2;display:grid;grid-template-columns:1.05fr .95fr;gap:50px;align-items:center}
.hero-copy h1{font-size:clamp(36px,5.6vw,64px);margin:18px 0 18px}
.hero-cta{display:flex;gap:14px;margin:30px 0 38px;flex-wrap:wrap}
.hero-stats{display:flex;gap:34px}
.hstat b{display:block;font-family:var(--font-display);font-size:clamp(26px,3vw,38px);font-weight:700;color:#fff;line-height:1}
.hstat span{font-size:12.5px;color:var(--txt-3)}

/* hero app window */
.hero-app{position:relative}
.ha-glow{position:absolute;inset:-30px;background:radial-gradient(circle at 60% 40%,rgba(225,29,56,.3),transparent 60%);filter:blur(40px);z-index:0}
.ha-window{position:relative;z-index:1;background:linear-gradient(180deg,#0F2744,#0A1626);border:1px solid var(--line-2);border-radius:20px;box-shadow:var(--shadow);overflow:hidden;animation:floaty 6s ease-in-out infinite}
@keyframes floaty{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
.ha-bar{display:flex;align-items:center;gap:7px;padding:12px 15px;border-bottom:1px solid var(--line);background:rgba(255,255,255,.03)}
.ha-bar span{width:10px;height:10px;border-radius:50%;background:var(--line-2)}
.ha-bar span:first-child{background:#FF5F57}
.ha-bar i{margin-left:8px;font-style:normal;font-size:12px;color:var(--txt-3);font-family:ui-monospace,monospace}
.ha-body{padding:16px;display:flex;flex-direction:column;gap:13px}
.ha-kpis{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.ha-kpi{background:rgba(255,255,255,.04);border:1px solid var(--line);border-radius:13px;padding:12px}
.ha-kpi small{font-size:10.5px;color:var(--txt-3);display:block}
.ha-kpi strong{font-family:var(--font-display);font-size:26px;color:#fff;line-height:1.2;display:block}
.ha-kpi em{font-size:10px;font-style:normal;color:var(--txt-3)}
.ha-kpi em.up{color:var(--green)}.ha-kpi em.amb{color:var(--yellow)}
.ha-fleet{background:rgba(255,255,255,.03);border:1px solid var(--line);border-radius:13px;padding:12px}
.ha-fleet-h{display:flex;justify-content:space-between;font-size:11.5px;color:var(--txt-2);margin-bottom:9px}
.ha-fleet-h .live{font-style:normal;color:var(--green);font-weight:700;font-size:10.5px}
.ha-list{display:flex;flex-direction:column;gap:6px}
.ha-item{display:flex;align-items:center;justify-content:space-between;font-size:12px;padding:7px 9px;border-radius:9px;background:rgba(255,255,255,.03)}
.ha-item b{color:#fff;font-weight:600;font-family:var(--font-display)}
.ha-st{font-size:10.5px;font-weight:700;padding:3px 9px;border-radius:99px}
.st-green{color:#5fe0a8;background:rgba(31,184,115,.16)}
.st-amber{color:#fbd36b;background:rgba(240,163,23,.16)}
.st-blue{color:#7fb0ff;background:rgba(59,130,246,.18)}
.st-red{color:#ff8b9b;background:rgba(225,29,56,.16)}
.ha-chart{background:rgba(255,255,255,.03);border:1px solid var(--line);border-radius:13px;padding:12px}
.ha-chart .bars{display:flex;align-items:flex-end;gap:5px;height:62px;margin-bottom:7px}
.ha-chart .bars span{flex:1;height:var(--h);background:linear-gradient(180deg,var(--red),rgba(225,29,56,.25));border-radius:4px 4px 0 0;animation:growBar 1s ease backwards}
.ha-chart small{font-size:10.5px;color:var(--txt-3)}
@keyframes growBar{from{height:0}}
.ha-float{position:absolute;z-index:3;font-size:12px;font-weight:600;background:rgba(15,39,68,.92);border:1px solid var(--line-2);backdrop-filter:blur(8px);padding:9px 13px;border-radius:12px;box-shadow:var(--shadow);color:var(--txt)}
.ha-float.f1{top:8%;left:-8%;animation:floaty 5s ease-in-out infinite}
.ha-float.f2{bottom:12%;right:-6%;color:#9be9c4;animation:floaty 5.5s ease-in-out infinite reverse}
@media (max-width:920px){.hero-in{grid-template-columns:1fr;gap:60px}.ha-float{display:none}}

.hero-scroll{position:absolute;bottom:24px;left:50%;transform:translateX(-50%);z-index:2;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--txt-3);display:flex;flex-direction:column;align-items:center;gap:8px}
.hero-scroll span{width:22px;height:34px;border:1.5px solid var(--line-2);border-radius:12px;position:relative}
.hero-scroll span::after{content:"";position:absolute;top:6px;left:50%;transform:translateX(-50%);width:4px;height:7px;border-radius:2px;background:var(--red);animation:scrolly 1.6s ease infinite}
@keyframes scrolly{0%{opacity:0;top:6px}40%{opacity:1}80%{opacity:0;top:18px}}

/* ---------- TRUST ---------- */
.trust{padding:34px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:rgba(255,255,255,.012)}
.trust-in{text-align:center}
.trust-in p{font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--txt-3);margin-bottom:16px}
.trust-row{display:flex;gap:34px;justify-content:center;flex-wrap:wrap;font-weight:600;color:var(--txt-2);font-size:15px}

/* ---------- SEC HEAD ---------- */
.sec-head{max-width:760px;margin-bottom:54px}
.sec-head.center{text-align:center;margin-left:auto;margin-right:auto}
.sec-head h2{margin:14px 0}

/* ---------- SOLVES ---------- */
.solve-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(330px,1fr));gap:16px}
.solve{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:12px;background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:18px;transition:.3s}
.solve:hover{border-color:var(--line-2);transform:translateY(-3px)}
.solve-bad{font-size:13.5px;color:var(--txt-2);display:flex;gap:8px;align-items:flex-start}
.solve-bad .x{color:var(--red);font-weight:800;flex-shrink:0}
.solve-arrow{color:var(--txt-3);font-size:18px}
.solve-good{font-size:13.5px;color:#fff;font-weight:600;display:flex;gap:8px;align-items:flex-start}
.solve-good .v{color:var(--green);font-weight:800;flex-shrink:0}
@media (max-width:560px){.solve{grid-template-columns:1fr}.solve-arrow{transform:rotate(90deg)}}

/* ---------- FEATURES ---------- */
.feat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.feat{position:relative;background:var(--surface);border:1px solid var(--line);border-radius:var(--r-lg);padding:26px 22px;overflow:hidden;transition:.35s cubic-bezier(.2,.8,.2,1)}
.feat:hover{transform:translateY(-6px);border-color:color-mix(in srgb,var(--accent) 50%,transparent)}
.feat-icon{width:56px;height:56px;border-radius:15px;display:grid;place-items:center;margin-bottom:16px;background:linear-gradient(160deg,#283142,#141a26);border:1px solid rgba(255,255,255,.10);box-shadow:inset 0 1px 0 rgba(255,255,255,.14),0 6px 16px rgba(0,0,0,.38)}
.feat-icon svg{width:28px;height:28px;filter:drop-shadow(0 1px 1px rgba(0,0,0,.55))}
.feat-tag{font-size:11px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--accent)}
.feat h3{font-size:18px;color:#fff;margin:7px 0 9px;line-height:1.25}
.feat p{font-size:13.5px;color:var(--txt-2);line-height:1.55}
.feat-glow{position:absolute;top:-60px;right:-60px;width:160px;height:160px;border-radius:50%;background:color-mix(in srgb,var(--accent) 26%,transparent);filter:blur(50px);opacity:0;transition:.4s}
.feat:hover .feat-glow{opacity:1}
@media (max-width:1000px){.feat-grid{grid-template-columns:repeat(2,1fr)}}
@media (max-width:560px){.feat-grid{grid-template-columns:1fr}}

/* ---------- FLOW ---------- */
.flow{background:linear-gradient(180deg,transparent,rgba(27,74,122,.07),transparent)}

/* ---------- TEAM ---------- */
.team-in{display:grid;grid-template-columns:1fr .9fr;gap:54px;align-items:center}
.team-points{list-style:none;display:flex;flex-direction:column;gap:13px;margin-top:26px}
.team-points li{display:flex;gap:12px;align-items:center;font-size:15px;color:var(--txt)}
.team-points li span{width:34px;height:34px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid var(--line);display:grid;place-items:center;flex-shrink:0}
.team-roles{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.role{display:flex;gap:13px;align-items:center;background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:16px;transition:.3s}
.role:hover{transform:translateY(-4px);border-color:var(--line-2);box-shadow:var(--shadow)}
.role-ic{width:46px;height:46px;border-radius:12px;background:linear-gradient(160deg,#283142,#141a26);border:1px solid rgba(255,255,255,.10);box-shadow:inset 0 1px 0 rgba(255,255,255,.14),0 5px 13px rgba(0,0,0,.38);display:grid;place-items:center;flex-shrink:0}
.role-ic svg{width:24px;height:24px;filter:drop-shadow(0 1px 1px rgba(0,0,0,.55))}
.role b{display:block;font-size:14.5px;color:#fff;font-family:var(--font-display)}
.role small{font-size:12px;color:var(--txt-3)}
@media (max-width:920px){.team-in{grid-template-columns:1fr;gap:40px}}
@media (max-width:460px){.team-roles{grid-template-columns:1fr}}

/* ---------- EASY ---------- */
.easy-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.easy-card{background:var(--surface);border:1px solid var(--line);border-radius:var(--r-lg);padding:26px;transition:.3s}
.easy-card:hover{transform:translateY(-5px);border-color:var(--line-2)}
.easy-card.big{grid-column:span 2;grid-row:span 2;background:linear-gradient(160deg,var(--surface-2),var(--surface));display:flex;flex-direction:column;justify-content:center}
.easy-card.big h3{font-size:26px;color:#fff;margin-bottom:12px}
.easy-card.big p{color:var(--txt-2);font-size:15px;line-height:1.6}
.easy-chips{display:flex;flex-wrap:wrap;gap:9px;margin-top:22px}
.easy-chips span{font-size:12.5px;font-weight:600;background:rgba(255,255,255,.05);border:1px solid var(--line);padding:8px 14px;border-radius:999px;color:var(--txt)}
.ec-ic{font-size:28px;margin-bottom:12px}
.easy-card h4{font-size:16px;color:#fff;margin-bottom:7px}
.easy-card p{font-size:13px;color:var(--txt-2);line-height:1.5}
@media (max-width:900px){.easy-grid{grid-template-columns:repeat(2,1fr)}.easy-card.big{grid-column:span 2;grid-row:auto}}
@media (max-width:520px){.easy-grid{grid-template-columns:1fr}.easy-card.big{grid-column:auto}}

/* ---------- CTA ---------- */
.cta{position:relative;text-align:center;overflow:hidden}
.cta-bg{position:absolute;inset:0;z-index:0}
.cta .m1{width:600px;height:600px;background:radial-gradient(circle,#E11D38,transparent 70%);top:-200px;left:20%;opacity:.35;filter:blur(80px);position:absolute;border-radius:50%}
.cta .m2{width:500px;height:500px;background:radial-gradient(circle,#1B4A7A,transparent 70%);bottom:-200px;right:15%;opacity:.5;filter:blur(80px);position:absolute;border-radius:50%}
.cta-in{position:relative;z-index:1;max-width:760px;margin:0 auto;display:flex;flex-direction:column;gap:22px;align-items:center}

/* ---------- FOOT ---------- */
.foot{border-top:1px solid var(--line);padding:46px 0;text-align:center}
.foot-in{display:flex;flex-direction:column;align-items:center;gap:10px}
.foot .brand{margin-bottom:4px}
.foot p{color:var(--txt-2)}
.foot small{color:var(--txt-3);font-size:12.5px}
</style>

<script is:inline>
// ---- nav scrolled ----
const nav = document.getElementById('nav');
const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 30);
onScroll(); addEventListener('scroll', onScroll, {passive:true});

// ---- reveal on scroll ----
const ro = new IntersectionObserver((es)=>{
  es.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('in'); ro.unobserve(e.target); } });
}, {threshold:.15, rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('[data-reveal]').forEach(el=>ro.observe(el));

// ---- count up (hero stats) ----
function countUp(el){
  const to = +el.dataset.count, sfx = el.dataset.suffix||'';
  let n=0; const step = Math.max(1, Math.round(to/40));
  const t = setInterval(()=>{ n+=step; if(n>=to){n=to;clearInterval(t);} el.textContent = n+sfx; }, 28);
}
const co = new IntersectionObserver((es)=>{
  es.forEach(e=>{ if(e.isIntersecting){ countUp(e.target); co.unobserve(e.target); } });
}, {threshold:.6});
document.querySelectorAll('[data-count]').forEach(el=>co.observe(el));

// ---- hero kpi ticks ----
document.querySelectorAll('.tick').forEach(el=>{
  const to=+el.dataset.to; let n=0; const step=Math.max(1,Math.round(to/30));
  const t=setInterval(()=>{ n+=step; if(n>=to){n=to;clearInterval(t);} el.textContent=n; },40);
});

// ---- hero fleet live list ----
const fleet = [
  ['UP-704','Trabajando','st-amber'],['UP-201','Alistamiento','st-red'],
  ['UP-611','Disponible','st-green'],['UP-188','Reservado','st-blue'],
  ['UP-330','Trabajando','st-amber'],['UP-509','Disponible','st-green'],
];
const haList = document.getElementById('haList');
if(haList){
  fleet.forEach(([id,st,cls],i)=>{
    const d=document.createElement('div'); d.className='ha-item';
    d.innerHTML=`<b>${id}</b><span class="ha-st ${cls}">${st}</span>`;
    d.style.animation=`growBar .5s ${i*.08}s backwards`;
    haList.appendChild(d);
  });
  // rotación de estados para "vida propia"
  const states=[['Trabajando','st-amber'],['Disponible','st-green'],['Reservado','st-blue'],['Alistamiento','st-red']];
  setInterval(()=>{
    const items=[...haList.children];
    const it=items[Math.floor(Math.random()*items.length)];
    const [st,cls]=states[Math.floor(Math.random()*states.length)];
    const badge=it.querySelector('.ha-st');
    badge.style.transition='.4s'; badge.style.opacity='0';
    setTimeout(()=>{ badge.className='ha-st '+cls; badge.textContent=st; badge.style.opacity='1'; },300);
  }, 2600);
}

// ---- particles ----
const pc = document.getElementById('particles');
if(pc){
  for(let i=0;i<22;i++){
    const p=document.createElement('i');
    p.style.left=Math.random()*100+'%';
    p.style.animationDuration=(8+Math.random()*10)+'s';
    p.style.animationDelay=(-Math.random()*12)+'s';
    const c=['#E11D38','#22D3EE','#4A7FB5'][i%3];
    p.style.background=c; p.style.width=p.style.height=(3+Math.random()*3)+'px';
    pc.appendChild(p);
  }
}
</script>
</body>
</html>
