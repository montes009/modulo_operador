---
// Demo interactiva embebida: simula el ciclo de vida real de un equipo
// dentro de Alcon Ops. Clickeable + autoplay. Sin dependencias.
const steps = [
  {
    id: 'cotizacion', n: '01', role: 'Comercial', icon: '📝',
    state: 'disponible', stateLabel: 'Disponible', tone: 'green',
    title: 'Se cotiza al cliente',
    desc: 'El equipo está en bodega, alistado por Taller. Comercial arma la cotización en segundos y la envía como PDF con las condiciones de la empresa.',
    ui: 'cot',
  },
  {
    id: 'reserva', n: '02', role: 'Comercial', icon: '🔒',
    state: 'reservado', stateLabel: 'Reservado', tone: 'blue',
    title: 'Se incluye en un alquiler → queda reservado',
    desc: 'Al sumar el equipo al alquiler, la máquina pasa a RESERVADO al instante. Nadie más puede tomarla: cero doble-reserva.',
    ui: 'alq',
  },
  {
    id: 'go', n: '03', role: 'Comercial', icon: '🚀',
    state: 'reservado', stateLabel: 'Reservado', tone: 'blue',
    title: 'GO: se activa el alquiler',
    desc: 'El “GO” confirma el alquiler y genera la orden de salida automáticamente para Logística. El equipo sigue reservado hasta el despacho.',
    ui: 'go',
  },
  {
    id: 'despacho', n: '04', role: 'Logística', icon: '🚚',
    state: 'trabajando', stateLabel: 'Trabajando', tone: 'amber',
    title: 'Logística despacha (RS)',
    desc: 'Coordinador asigna transportador y despacha. La máquina pasa a TRABAJANDO. Toda la ruta queda trazada en logística.',
    ui: 'log',
  },
  {
    id: 'obra', n: '05', role: 'Operador en obra', icon: '📍',
    state: 'trabajando', stateLabel: 'En obra', tone: 'amber',
    title: 'Trazabilidad y mantenimiento en sitio',
    desc: 'El operador registra llegada, fotos, checklist y firma del receptor. Si toca preventivo, se genera una Orden de Servicio en obra (OS-####).',
    ui: 'obra',
  },
  {
    id: 'devolucion', n: '06', role: 'Comercial / Logística', icon: '↩️',
    state: 'devolucion', stateLabel: 'En devolución', tone: 'purple',
    title: 'Se solicita la devolución',
    desc: 'Con un clic se emite la orden de recogida (RE). El alquiler queda pendiente de recogida y se facturan los días reales o por cortes.',
    ui: 'dev',
  },
  {
    id: 'taller', n: '07', role: 'Taller', icon: '🔧',
    state: 'alistamiento', stateLabel: 'Alistamiento', tone: 'red',
    title: 'Regresa a Taller: checklist',
    desc: 'La RE devuelve el equipo a Taller. Se corre el checklist de seguridad obligatorio (parada de emergencia, controles, batería) antes de volver a la calle.',
    ui: 'taller',
  },
  {
    id: 'listo', n: '08', role: 'Taller', icon: '✅',
    state: 'disponible', stateLabel: 'Disponible', tone: 'green',
    title: 'Disponible otra vez',
    desc: 'Checklist aprobado: el equipo vuelve a DISPONIBLE, listo para el siguiente alquiler. El ciclo se cierra sin papeles ni vacíos.',
    ui: 'cot',
  },
];
---

<div class="demo" id="flowDemo">
  <div class="demo-frame">
    <!-- chrome de ventana -->
    <div class="demo-bar">
      <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
      <div class="demo-url"><span class="lock">🔒</span> app.alconops.com<span class="caret">|</span></div>
      <div class="demo-live"><span class="pulse"></span> EN VIVO</div>
    </div>

    <div class="demo-body">
      <!-- pasos -->
      <aside class="demo-steps" role="tablist" aria-label="Flujo del alquiler">
        {steps.map((s, i) => (
          <button class={"step" + (i === 0 ? ' active' : '')} data-i={i} role="tab" aria-selected={i===0}>
            <span class="step-n">{s.n}</span>
            <span class="step-tx">
              <span class="step-role">{s.icon} {s.role}</span>
              <span class="step-title">{s.title}</span>
            </span>
          </button>
        ))}
      </aside>

      <!-- pantalla viva -->
      <div class="demo-screen">
        <div class="screen-top">
          <div class="machine-card" id="machineCard">
            <div class="mc-head">
              <div class="mc-id">UP-704</div>
              <div class="mc-sub">Plataforma articulada · 16 m</div>
            </div>
            <div class="mc-pill" id="mcPill">Disponible</div>
          </div>
          <div class="role-badge" id="roleBadge">📝 Comercial</div>
        </div>

        <div class="screen-stage" id="screenStage"><!-- UI inyectada por JS --></div>

        <div class="screen-desc">
          <h4 id="stepTitle">Se cotiza al cliente</h4>
          <p id="stepDesc"></p>
        </div>

        <div class="screen-foot">
          <div class="progress"><span id="progressBar"></span></div>
          <div class="screen-ctrls">
            <button class="ctrl" id="btnPrev" aria-label="Anterior">‹</button>
            <button class="ctrl play" id="btnPlay" aria-label="Reproducir">❚❚</button>
            <button class="ctrl" id="btnNext" aria-label="Siguiente">›</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ steps }}>
(function(){
  const root = document.getElementById('flowDemo');
  if(!root) return;
  const stepBtns = [...root.querySelectorAll('.step')];
  const pill = root.querySelector('#mcPill');
  const card = root.querySelector('#machineCard');
  const roleBadge = root.querySelector('#roleBadge');
  const stage = root.querySelector('#screenStage');
  const titleEl = root.querySelector('#stepTitle');
  const descEl = root.querySelector('#stepDesc');
  const bar = root.querySelector('#progressBar');
  const btnPlay = root.querySelector('#btnPlay');

  const toneColor = {
    green:['#1FB873','rgba(31,184,115,.14)'], blue:['#3B82F6','rgba(59,130,246,.16)'],
    amber:['#F0A317','rgba(240,163,23,.16)'], purple:['#8B5CF6','rgba(139,92,246,.16)'],
    red:['#E11D38','rgba(225,29,56,.16)'],
  };

  function ui(kind){
    const row = (a,b,t='') => `<div class="ui-row"><span>${a}</span><b class="${t}">${b}</b></div>`;
    switch(kind){
      case 'cot': return `<div class="ui-doc"><div class="ui-doc-h">COTIZACIÓN · COT-0241</div>${row('Cliente','Constructora del Río')}${row('Equipo','UP-704 · Plataforma 16m')}${row('Tarifa / día','$ 420.000')}${row('Total estimado','$ 6.300.000','hl')}<div class="ui-cta">📄 Enviar PDF</div></div>`;
      case 'alq': return `<div class="ui-doc"><div class="ui-doc-h">ALQUILER · ALQ-0188</div>${row('Equipo asignado','UP-704 ✓')}${row('Duración','15 días')}${row('Inicio','Lun 29')}<div class="ui-flag blue">🔒 Equipo reservado — bloqueado para otros</div></div>`;
      case 'go':  return `<div class="ui-doc"><div class="ui-doc-h">CONFIRMAR ALQUILER</div>${row('Estado','Borrador → Activo')}${row('Orden de salida','Generada automáticamente')}<div class="ui-cta go">🚀 GO</div></div>`;
      case 'log': return `<div class="ui-doc"><div class="ui-doc-h">ORDEN LOGÍSTICA · RS-0188</div>${row('Movimiento','🚀 Entrega / despacho')}${row('Transportador','Transportes Andina')}${row('Destino','Obra Norte · Km 12')}<div class="ui-flag amber">🚚 Equipo en ruta → Trabajando</div></div>`;
      case 'obra':return `<div class="ui-doc"><div class="ui-doc-h">OPERADOR · TRAZABILIDAD</div>${row('Llegada a obra','08:42 ✓')}${row('Checklist','7/7 ✓')}${row('Firma receptor','✍️ registrada')}<div class="ui-photos"><span>📷</span><span>📷</span><span>📷</span><span class="more">+4</span></div></div>`;
      case 'dev': return `<div class="ui-doc"><div class="ui-doc-h">DEVOLUCIÓN · RE-0188</div>${row('Días reales','15')}${row('Facturación','Por cortes ✓')}${row('Recogida','Programada')}<div class="ui-flag purple">↩️ Pendiente de recogida</div></div>`;
      case 'taller':return `<div class="ui-doc"><div class="ui-doc-h">CHECKLIST DE ALISTAMIENTO</div>${row('Parada emergencia','✓ OK','ok')}${row('Controles plataforma','✓ OK','ok')}${row('Voltaje batería','✓ OK','ok')}${row('Mecánico','J. Pérez')}<div class="ui-cta">📋 Aprobar</div></div>`;
      default: return '';
    }
  }

  let idx = 0, playing = true, timer = null;
  const DUR = 4200;

  function render(i, animate=true){
    idx = i;
    const s = steps[i];
    stepBtns.forEach((b,k)=>{ b.classList.toggle('active', k===i); b.setAttribute('aria-selected', k===i); });
    const active = stepBtns[i];
    if(active) active.scrollIntoView({block:'nearest', behavior:'smooth'});

    // pill + card glow
    const [c,bg] = toneColor[s.tone];
    pill.textContent = s.stateLabel;
    pill.style.color = c; pill.style.background = bg; pill.style.borderColor = c;
    card.style.setProperty('--glow', bg);
    card.classList.remove('flash'); void card.offsetWidth; card.classList.add('flash');

    roleBadge.textContent = `${s.icon} ${s.role}`;
    titleEl.textContent = s.title;
    descEl.textContent = s.desc;

    stage.classList.remove('swap'); void stage.offsetWidth;
    stage.innerHTML = ui(s.ui);
    if(animate) stage.classList.add('swap');

    bar.style.transition = 'none'; bar.style.width = '0%'; void bar.offsetWidth;
    if(playing){ bar.style.transition = `width ${DUR}ms linear`; bar.style.width = '100%'; }
    else { bar.style.transition='width .3s'; bar.style.width = ((i+1)/steps.length*100)+'%'; }
  }

  function next(){ render((idx+1) % steps.length); }
  function schedule(){ clearTimeout(timer); if(playing) timer = setTimeout(()=>{ next(); schedule(); }, DUR); }

  function setPlaying(p){
    playing = p;
    btnPlay.textContent = p ? '❚❚' : '▶';
    btnPlay.classList.toggle('paused', !p);
    render(idx, false);
    schedule();
  }

  stepBtns.forEach((b,k)=> b.addEventListener('click', ()=>{ render(k); if(playing) schedule(); }));
  root.querySelector('#btnNext').addEventListener('click', ()=>{ render((idx+1)%steps.length); if(playing) schedule(); });
  root.querySelector('#btnPrev').addEventListener('click', ()=>{ render((idx-1+steps.length)%steps.length); if(playing) schedule(); });
  btnPlay.addEventListener('click', ()=> setPlaying(!playing));

  // pausa al hover, reanuda al salir
  root.querySelector('.demo-screen').addEventListener('mouseenter', ()=>{ clearTimeout(timer); });
  root.querySelector('.demo-screen').addEventListener('mouseleave', ()=>{ if(playing) schedule(); });

  // arranca cuando entra en viewport
  let started=false;
  const io = new IntersectionObserver((es)=>{
    es.forEach(e=>{ if(e.isIntersecting && !started){ started=true; render(0); schedule(); } });
  }, {threshold:.35});
  io.observe(root);
  render(0,false); // estado inicial sin animar
})();
</script>

<style>
.demo{perspective:1600px}
.demo-frame{
  background:linear-gradient(180deg,#0E2138,#0A1626);
  border:1px solid var(--line-2);border-radius:var(--r-lg);
  box-shadow:var(--shadow);overflow:hidden;
  transform:rotateX(2deg);transition:transform .6s ease;
}
.demo-frame:hover{transform:rotateX(0deg)}
.demo-bar{display:flex;align-items:center;gap:8px;padding:13px 16px;background:rgba(255,255,255,.03);border-bottom:1px solid var(--line)}
.dot{width:11px;height:11px;border-radius:50%}
.dot.r{background:#FF5F57}.dot.y{background:#FEBC2E}.dot.g{background:#28C840}
.demo-url{flex:1;margin-left:10px;background:rgba(0,0,0,.3);border:1px solid var(--line);border-radius:8px;padding:6px 12px;font-size:12.5px;color:var(--txt-2);font-family:ui-monospace,monospace;display:flex;align-items:center;gap:7px}
.demo-url .lock{font-size:10px}
.caret{color:var(--red);animation:blink 1.1s steps(1) infinite;margin-left:2px}
@keyframes blink{50%{opacity:0}}
.demo-live{display:flex;align-items:center;gap:6px;font-size:11px;font-weight:800;letter-spacing:.1em;color:#FF7A8A}
.pulse{width:8px;height:8px;border-radius:50%;background:var(--red);box-shadow:0 0 0 0 rgba(225,29,56,.6);animation:pulse 1.6s infinite}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(225,29,56,.55)}70%{box-shadow:0 0 0 9px rgba(225,29,56,0)}100%{box-shadow:0 0 0 0 rgba(225,29,56,0)}}

.demo-body{display:grid;grid-template-columns:300px 1fr;min-height:460px}
.demo-steps{border-right:1px solid var(--line);padding:12px;display:flex;flex-direction:column;gap:4px;overflow-y:auto;max-height:520px;background:rgba(0,0,0,.12)}
.step{display:flex;gap:12px;align-items:flex-start;text-align:left;background:transparent;border:1px solid transparent;border-radius:12px;padding:11px 12px;cursor:pointer;color:var(--txt-2);transition:.25s;font-family:var(--font)}
.step:hover{background:rgba(255,255,255,.04);color:var(--txt)}
.step.active{background:linear-gradient(120deg,rgba(225,29,56,.16),rgba(225,29,56,.04));border-color:rgba(225,29,56,.4);color:#fff}
.step-n{font-family:var(--font-display);font-size:13px;font-weight:700;color:var(--txt-3);min-width:22px}
.step.active .step-n{color:var(--red)}
.step-tx{display:flex;flex-direction:column;gap:3px}
.step-role{font-size:11px;font-weight:700;letter-spacing:.04em;opacity:.85}
.step-title{font-size:13.5px;font-weight:600;line-height:1.3}

.demo-screen{display:flex;flex-direction:column;padding:22px 24px;gap:18px;position:relative;background:radial-gradient(120% 80% at 80% -10%,rgba(43,93,147,.18),transparent 60%)}
.screen-top{display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap}
.machine-card{position:relative;display:flex;align-items:center;gap:16px;background:var(--surface);border:1px solid var(--line-2);border-radius:16px;padding:14px 18px;box-shadow:0 0 0 1px var(--glow,transparent),0 18px 40px -24px var(--glow,#000)}
.machine-card.flash{animation:flash .6s ease}
@keyframes flash{0%{transform:scale(.97)}55%{transform:scale(1.015)}100%{transform:scale(1)}}
.mc-head{display:flex;flex-direction:column}
.mc-id{font-family:var(--font-display);font-weight:700;font-size:20px;color:#fff;letter-spacing:.02em}
.mc-sub{font-size:11.5px;color:var(--txt-3)}
.mc-pill{font-size:12.5px;font-weight:800;padding:6px 13px;border-radius:999px;border:1px solid;transition:all .5s ease}
.role-badge{font-size:12.5px;font-weight:700;color:var(--txt);background:rgba(255,255,255,.06);border:1px solid var(--line);padding:8px 14px;border-radius:999px;transition:.4s}

.screen-stage{flex:1;display:flex;align-items:center;justify-content:center}
.screen-stage.swap .ui-doc{animation:swapIn .5s cubic-bezier(.2,.8,.2,1)}
@keyframes swapIn{from{opacity:0;transform:translateY(14px) scale(.98)}to{opacity:1;transform:none}}
.ui-doc{width:100%;max-width:420px;background:linear-gradient(180deg,#fff,#f4f7fb);color:#0B1F38;border-radius:14px;padding:18px 20px;box-shadow:0 30px 60px -25px rgba(0,0,0,.7)}
.ui-doc-h{font-family:var(--font-display);font-weight:700;font-size:13px;letter-spacing:.06em;color:var(--red-deep);padding-bottom:10px;margin-bottom:6px;border-bottom:1px dashed rgba(11,31,56,.18)}
.ui-row{display:flex;justify-content:space-between;gap:14px;padding:7px 0;font-size:13.5px;border-bottom:1px solid rgba(11,31,56,.07)}
.ui-row span{color:#5b6b80}
.ui-row b{font-weight:700;color:#0B1F38}
.ui-row b.hl{color:var(--green-deep);font-size:15px}
.ui-row b.ok{color:var(--green-deep)}
.ui-cta{margin-top:13px;text-align:center;background:var(--grad-navy);color:#fff;font-weight:700;padding:10px;border-radius:10px;font-size:13.5px}
.ui-cta.go{background:var(--grad-red)}
.ui-flag{margin-top:12px;padding:9px 12px;border-radius:10px;font-size:12.5px;font-weight:700;text-align:center}
.ui-flag.blue{background:rgba(59,130,246,.14);color:#1f5fc0}
.ui-flag.amber{background:rgba(240,163,23,.16);color:#9a6300}
.ui-flag.purple{background:rgba(139,92,246,.16);color:#6d3fc0}
.ui-photos{display:flex;gap:8px;margin-top:13px}
.ui-photos span{flex:1;aspect-ratio:1.4;background:linear-gradient(135deg,#dde6f1,#c4d2e3);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px}
.ui-photos .more{background:#0B1F38;color:#fff;font-size:13px;font-weight:700}

.screen-desc h4{font-family:var(--font-display);font-size:18px;color:#fff;margin-bottom:4px}
.screen-desc p{font-size:13.8px;color:var(--txt-2);line-height:1.55;min-height:44px}

.screen-foot{display:flex;align-items:center;gap:16px}
.progress{flex:1;height:5px;border-radius:99px;background:rgba(255,255,255,.08);overflow:hidden}
.progress span{display:block;height:100%;width:0;background:var(--grad-red);border-radius:99px}
.screen-ctrls{display:flex;gap:7px}
.ctrl{width:36px;height:36px;border-radius:50%;border:1px solid var(--line-2);background:rgba(255,255,255,.05);color:#fff;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.2s}
.ctrl:hover{background:rgba(255,255,255,.14);transform:scale(1.08)}
.ctrl.play{background:var(--grad-red);border-color:transparent;font-size:11px;letter-spacing:1px}
.ctrl.play.paused{font-size:13px}

@media (max-width:860px){
  .demo-body{grid-template-columns:1fr}
  .demo-steps{flex-direction:row;overflow-x:auto;max-height:none;border-right:0;border-bottom:1px solid var(--line)}
  .step{min-width:215px}
  .demo-frame{transform:none}
}
</style>
